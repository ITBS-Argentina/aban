<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="l10n_ar_dj_arba_view_list" model="ir.ui.view">
        <field name="name">l10n_ar.dj.arba.view.list</field>
        <field name="model">l10n_ar.dj.arba</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'close'" decoration-warning="state == 'open'">
                <field name="display_name"/>
                <field name="name"/>
                <field name="state"/>
                <field name="is_refund"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <button name="action_update_status" type="object" title="Update" help="Update the status via ws" icon="fa-refresh"/>
            </list>
        </field>
    </record>

    <record id="l10n_ar_dj_arba_view_form" model="ir.ui.view">
        <field name="name">l10n_ar.dj.arba.view.form</field>
        <field name="model">l10n_ar.dj.arba</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open" type="object" string="Open" help="Connect to webservice" invisible="state != 'draft'"/>
                    <button name="action_find_existing" type="object" string="Find" help="Find open DDJJ and load info" invisible="state != 'draft'" groups="base.group_no_one"/>
                    <button name="action_update_status" type="object" string="Update Status" help="Update the status via ws" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <span class="oe_title" colspan="2">
                            Select a date to calculate the applicable period
                        </span>
                        <field name="company_id" readonly="state != 'draft'" groups="base.group_multi_company"/>
                        <field name="date" readonly="state != 'draft'"/>
                        <field name="display_name" string="It will apply to"/>
                    </group>
                    <group string="ARBA Information">
                        <field name="name"/>
                        <field name="open_date"/>
                        <field name="due_date"/>
                        <field name="close_date"/>
                    </group>
                    <notebook>
                        <page string="Withholdings">
                            <field name="l10n_ar_withholding_ids" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="l10n_ar_dj_arba_view_search" model="ir.ui.view">
        <field name="name">l10n_ar.dj.arba.view.search</field>
        <field name="model">l10n_ar.dj.arba</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="date"/>
                <field name="state"/>
                <filter name="groupby_date" string="Period" context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <record id="l10n_ar_dj_arba_action" model="ir.actions.act_window">
        <field name="name">DDJJ ARBA</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_ar.dj.arba</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_groupby_date': 1}</field>
    </record>

    <!-- This Menu Item must have a parent and an action -->
    <menuitem id="l10n_ar_dj_arba_menu_act" name="DDJJ ARBA" parent="l10n_ar.account_reports_ar_statements_menu" action="l10n_ar_dj_arba_action" sequence="50"/>

</odoo>
