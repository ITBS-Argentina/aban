<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.partner_view_buttons"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object" groups="account.group_account_invoice"
                    name="action_open_reconcile" icon="fa-dollar">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Payment </span>
                        <span class="o_stat_text">Matching</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
    <record model="ir.actions.server" id="action_partner_ledger">
            <field name="name">Partner Ledger Report</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="binding_model_id" ref="model_res_partner" />
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.open_mass_partner_ledger()
            </field>
    </record>

    <record model="ir.actions.server" id="action_aged_receivable">
            <field name="name">Aged Receivable Report</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="binding_model_id" ref="model_res_partner" />
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.open_mass_aged_receivable()
            </field>
    </record>

    <record model="ir.actions.server" id="action_aged_payable">
            <field name="name">Aged Payable Report</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="binding_model_id" ref="model_res_partner" />
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.open_mass_aged_payable()
            </field>
    </record>

    <record id="res_partner_view_search" model="ir.ui.view">
        <field name="name">res.partner.search.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="before">
                <filter name="debt_to_charge" string="Deuda a cobrar" domain="[('credit','>',0)]"/>
                <filter name="customer_balance" string="Saldo a favor de cliente" domain="[('credit','&lt;',0)]"/>
                <filter name="debt_to_pay" string="Deuda a pagar" domain="[('debit','>',0)]"/>
                <filter name="vendor_balance" string="Saldo a favor con proveedor" domain="[('debit','&lt;',0)]"/>
                <separator/>
            </xpath>
        </field>
    </record>


    <record model="ir.ui.view" id="res_partner_view_form">
        <field name="name">res.partner.view.form.followup.ux</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account_followup.res_partner_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='open_follow_up_report']" position="attributes">
                <attribute name="invisible">not has_moves</attribute>
            </xpath>

            <xpath expr="//button[@name='open_follow_up_report']//span[hasclass('o_stat_text')]" position="replace">
                <span class="o_stat_text">Follow-up Report</span>
            </xpath>
            <xpath expr="//button[@name='action_open_reconcile']" position="after">
                <button class="oe_stat_button" type="action" groups="account.group_account_invoice"
                        name="%(account_accountant_ux.action_partner_ledger)d" icon="fa-book">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Partner</span>
                        <span class="o_stat_text">Ledger</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>


</odoo>
