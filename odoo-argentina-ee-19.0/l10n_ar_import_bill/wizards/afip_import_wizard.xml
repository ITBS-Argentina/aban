<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- vista para importar desde config settings, luego termina llamando a la otra -->
    <record id="view_afip_import_file_wizard_form" model="ir.ui.view">
        <field name="name">afip.import.wizard.form</field>
        <field name="model">afip.import.wizard</field>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <form>
                <div class="alert alert-warning" role="status">
                   <i class="fa fa-exclamation-triangle" title="Warning"/>
                   <span>Importing sales from ARCA: Only invoices dated before the accounting start date will be imported.</span>
                </div>

                <group>
                    <field name="journal_domain" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="journal_id" options="{'no_create': True}"/>
                    <field name="counterpart_account_id" required="True"/>
                    <field name="file_data" filename="file_name" required="True"/>
                    <field name="file_name" invisible="1"/>
                </group>

                <footer>
                    <button name="action_process_file" type="object" string="Continue" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_afip_import_wizard_form" model="ir.ui.view">
        <field name="name">afip.import.wizard.form</field>
        <field name="model">afip.import.wizard</field>
        <field name="arch" type="xml">
            <form >
                <div class="alert alert-info" role="status" invisible="total_bills_exists == 0">
                   <i class="fa fa-info-circle" title="Info"/> <span invisible="total_bills_exists == 0">Invoices highlighted in yellow will not be created because they already exist. </span>
                </div>

                <div class="alert alert-warning" role="status" invisible="not context.get('from_settings')">
                   <i class="fa fa-exclamation-triangle" title="Warning"/>
                   <span>Importing sales from ARCA: Only invoices dated before the accounting start date will be imported.</span>
                </div>

                <group>
                    <group>
                    <field name="total_bills_to_create"  class="oe_inline"/>
                    </group>
                    <group>
                    <field name="total_bills_exists"  class="oe_inline"/>
                    </group>
                </group>
                <group>
                    <field name="auto_validate"/>
                </group>

                <field name="line_ids" nolabel="1" readonly="1">

                    <list decoration-warning="exists == True">
                        <field name="document_type"/>
                        <field name="invoice_number"/>
                        <field name="partner_name"/>
                        <field name="partner_vat"/>
                        <field name="date_invoice"/>
                        <field name="currency"/>
                        <field name="amount_total"/>
                        <button name="action_remove" type="object" icon="fa-trash-o" title="Eliminar" class="oe_inline"/>
                    </list>

                </field>

                <footer>

                    <button name="action_confirm" type="object" string="Crear Facturas" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>

                </footer>
            </form>
        </field>
    </record>
</odoo>
