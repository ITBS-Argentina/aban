<?xml version="1.0"?>
<odoo>
    <record model="res.groups" id="group_restrict_change_currency_exchange">
        <field name="name">Restrict Change Invoice Currency Exchange</field>
    </record>

    <record id="group_reference_on_tree_and_main_form" model="res.groups">
        <field name="name">Show invoice reference field on tree and main form views</field>
    </record>

    <record id="account.journal_comp_rule" model="ir.rule">
        <field name="name">Journal multi-company</field>
        <field name="model_id" ref="model_account_journal"/>
        <field name="domain_force">
            [
                '|',
                ('company_id', 'in', company_ids),
                '&amp;',
                ('company_id', 'parent_of', company_ids),
                ('shared_to_branches', '=', True)
            ]
        </field>
    </record>

</odoo>
