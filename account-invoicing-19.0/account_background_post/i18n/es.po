#. module: account_background_post
#: model_terms:ir.ui.view,arch_db:account_background_post.view_move_form
msgid ""
"This invoice will be automatically validated by the background process. If "
"you validate it manually, the background flag will be automatically removed."
msgstr ""
"Esta factura se validará automáticamente mediante un proceso en segundo "
"plano. Si la valida manualmente, la marca de validación en segundo plano se "
"eliminará."

#. module: account_background_post
#: model_terms:ir.ui.view,arch_db:account_background_post.view_account_invoice_filter
